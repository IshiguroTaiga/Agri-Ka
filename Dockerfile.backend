# Dockerfile for Express SQL API Backend
FROM node:22-alpine

WORKDIR /app

# Copy package.json and install dependencies
COPY server/package*.json ./
RUN npm install --omit=dev

# Copy server application files
COPY server/ .

# Create volume mount point for persistent SQL database
VOLUME ["/app/data"]

EXPOSE 5000

ENV PORT=5000
ENV NODE_ENV=production
ENV DATA_DIR=/app/data

CMD ["node", "index.js"]
